<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
  </startup>
  <runtime>
    <!--
      Bakin games are usually distributed as a downloaded .zip. Files extracted from a
      downloaded archive carry the Windows "mark-of-the-web" (a Zone.Identifier alternate
      data stream, ZoneId=3). .NET Framework's Assembly.LoadFrom REFUSES to load an assembly
      that carries that marker (FileLoadException / NotSupportedException, HRESULT 0x80131515:
      "load an assembly from a network location...") unless this switch is enabled.

      This broke `apply` (export) on games whose bakinplayer.exe was still marked, even though
      `list`/extract worked — because extract never loads bakinplayer.exe (it only loads
      common.dll / SharpKmyCore.dll, which happened not to be marked). Enabling the switch makes
      LoadFrom treat mark-of-the-web assemblies as trusted, exactly as it already does for local
      ones. ADDITIVE: assemblies with no zone marker are loaded identically to before.
    -->
    <loadFromRemoteSources enabled="true" />
  </runtime>
</configuration>