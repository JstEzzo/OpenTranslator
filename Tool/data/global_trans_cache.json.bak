    "Executioner (2.0x)": "Carrasco (2,0x)",
    "Necromaster (2.0x)": "Necromestre (2,0x)",
    "Executioner (8.0x)": "Carrasco (8,0x)",
    "Gregory (15.0x)": "Gregório (15,0x)",
    "Dark Purupuru (15.0x)": "Purupuru Escuro (15,0x)",
